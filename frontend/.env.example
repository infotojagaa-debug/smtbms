# OPERATIONAL NODE BACKEND LINKAGE
# Target URL where the Node.js / Express backend is hosted.
# e.g., https://smtbms-api.onrender.com for production / http://localhost:5000 for local
REACT_APP_API_URL=http://localhost:5000

# REAL-TIME SYNCHRONIZATION LINKAGE (Socket.io)
# Target URL where the Socket event stream is hosted.
# Usually identical to the API URL.
REACT_APP_SOCKET_URL=http://localhost:5000
